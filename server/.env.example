# ─────────────────────────────────────────────
# HR Workflow Platform — Server Environment
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# MongoDB connection string
# Local:  mongodb://localhost:27017/hr_workflow
# Atlas:  mongodb+srv://user:password@cluster.mongodb.net/hr_workflow
MONGO_URI=mongodb://localhost:27017/hr_workflow

# JWT secret key — use a long random string in production
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# JWT expiry
JWT_EXPIRES_IN=7d

# Port the Express server listens on
PORT=5000

# Client URL — for CORS (adjust if your Vite dev server uses a different port)
CLIENT_URL=http://localhost:5173
